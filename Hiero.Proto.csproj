<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<LangVersion>14</LangVersion>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

	<PropertyGroup>
		<Authors>Hiero Hackers</Authors>
		<Copyright>Copyright © $(Authors) $([System.DateTime]::Now.ToString('yyyy'))</Copyright>
		<Description>Unofficial SDK Consensus Node for the Hedera Hashgraph network</Description>
		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>
		<IncludeSymbols>False</IncludeSymbols>
		<PackageId>$(AssemblyName)</PackageId>
		<PackageOutputPath>../../sdk-package</PackageOutputPath>
		<PackageReleaseNotes>Unofficial and to be used for internal purposes</PackageReleaseNotes>
		<PackageTags>hiero;ledger;consensus;node;c#;hedera;hashgraph;sdk</PackageTags>
		<RepositoryUrl>https://github.com/hiero-hackers/hiero-sdk-csharp</RepositoryUrl>
		<Title>$(AssemblyName)</Title>
		<Version>0.0.0</Version>
	</PropertyGroup>

	<ItemGroup>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>Hiero.SDK</_Parameter1>
		</AssemblyAttribute>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>Hiero.Tests.SDK</_Parameter1>
		</AssemblyAttribute>
		<AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
			<_Parameter1>Hiero.Tests.Integration</_Parameter1>
		</AssemblyAttribute>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Google.Protobuf" Version="3.34.1" />
		<PackageReference Include="Grpc" Version="2.46.6" />
		<PackageReference Include="Grpc.Tools" Version="2.80.0">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
	</ItemGroup>

	<PropertyGroup>
		<HapiProtoRoot>$(MSBuildProjectDirectory)\hapi\hapi\src\main\proto</HapiProtoRoot>
		<HederaProtoRoot>$(MSBuildProjectDirectory)\hapi\hedera-protobuf-java-api\src\main\proto</HederaProtoRoot>
	</PropertyGroup>

	<ItemGroup>
		<Protobuf GrpcServices="Both" ProtoRoot="$(HapiProtoRoot)" Include="$(HapiProtoRoot)\**\*.proto" AdditionalImportDirs="$(HederaProtoRoot)" />
		<Protobuf GrpcServices="Both" ProtoRoot="$(HederaProtoRoot)" Include="$(HederaProtoRoot)\**\*.proto" AdditionalImportDirs="$(HapiProtoRoot)" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Hiero\Hiero.csproj" />
	</ItemGroup>

</Project>