      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "direction": "backward",
          "editorMode": "code",
          "expr": "{service_name=\"benchmark-logs\"}\n|= `MERKLE_DB`\n|~ `DataFileCompactor` or `DataFileCollection` \n|~ `Finished writing (file|new compaction file)|Deleted compacted files`\n| regexp `store=(?P<store>[^,]+),`\n| regexp `size=(?P<add_size>\\d+),`\n| regexp `compaction_level=(?P<compaction_level>\\d+),`\n| regexp `count=(?P<del_count>\\d+),`\n| regexp `saved=(?P<del_size>\\d+)`\n| label_format files_count=`{{ if .add_size }}1{{ else }}-{{ .del_count }}{{ end }}`, files_size=`{{ if .add_size }}{{ .add_size }}{{ else }}-{{ .del_size }}{{ end }}` \n| keep store, compaction_level, files_count, files_size\n",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "File logs",
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "delimiter": ",",
            "format": "json",
            "source": "labels"
          }
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
                "Time",
                "Line",
                "compaction_level",
                "files_count",
                "files_size",
                "store"
              ]
            }
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "includeByName": {},
            "indexByName": {
              "Line": 5,
              "Time": 0,
              "compaction_level": 2,
              "files_count": 3,
              "files_size": 4,
              "store": 1
            },
            "renameByName": {}
          }
        }
      ],
      "type": "table"
    }
